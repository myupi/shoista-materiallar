rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /lessonTopics/{topicId} {
      allow read: if true;
      allow create: if isValidLessonTopic();
      allow update, delete: if false;
    }

    function isValidLessonTopic() {
      return request.resource.data.keys().hasOnly(['title', 'url', 'createdAt'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 120
        && request.resource.data.url is string
        && request.resource.data.url.matches('https?://.+')
        && request.resource.data.url.size() <= 500
        && request.resource.data.createdAt == request.time;
    }
  }
}
